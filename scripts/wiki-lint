#!/usr/bin/env bash
# wiki-lint — Mechanical health checks for the wiki vault
#
# Usage:
#   wiki-lint                Run all checks
#   wiki-lint frontmatter    Check for missing required frontmatter
#   wiki-lint links          Check for broken wikilinks
#   wiki-lint orphans        Find pages with no inbound links
#   wiki-lint raw            Check raw source frontmatter compliance
#
# Environment:
#   WIKI_VAULT  Path to the wiki vault (default: /data/vault or ~/Obsidian/home-wiki)

set -euo pipefail

# Resolve vault path
if [[ -n "${WIKI_VAULT:-}" ]]; then
  VAULT="$WIKI_VAULT"
elif [[ -d /data/vault ]]; then
  VAULT=/data/vault
elif [[ -d "$HOME/Obsidian/home-wiki" ]]; then
  VAULT="$HOME/Obsidian/home-wiki"
else
  echo "Error: Cannot find wiki vault. Set WIKI_VAULT." >&2
  exit 1
fi

ERRORS=0

# Get all wiki pages (exclude raw/, private/, .obsidian/)
find_wiki_pages() {
  find "$VAULT" -name '*.md' -type f \
    -not -path "$VAULT/raw/*" \
    -not -path "$VAULT/private/*" \
    -not -path "$VAULT/.obsidian/*" | sort
}

find_raw_files() {
  find "$VAULT/raw" -name '*.md' -type f 2>/dev/null | sort
}

check_frontmatter() {
  echo "=== Frontmatter Check ==="
  local count=0

  while read -r file; do
    local rel="${file#"$VAULT"/}"

    # Must start with ---
    if ! head -1 "$file" | grep -q '^---'; then
      echo "  FAIL: $rel — missing frontmatter"
      ((count++))
      continue
    fi

    # Check required fields
    local has_title=false has_tags=false has_date=false
    local in_fm=false
    while IFS= read -r line; do
      if [[ "$line" == "---" ]]; then
        if $in_fm; then break; else in_fm=true; continue; fi
      fi
      if $in_fm; then
        [[ "$line" =~ ^title: ]] && has_title=true
        [[ "$line" =~ ^tags: ]] && has_tags=true
        [[ "$line" =~ ^date: ]] && has_date=true
      fi
    done < "$file"

    local missing=""
    $has_title || missing+="title "
    $has_tags || missing+="tags "
    $has_date || missing+="date "

    if [[ -n "$missing" ]]; then
      echo "  WARN: $rel — missing: $missing"
      ((count++))
    fi
  done < <(find_wiki_pages)

  if [[ "$count" -eq 0 ]]; then
    echo "  OK"
  fi
  ERRORS=$((ERRORS + count))
  echo
}

check_raw_frontmatter() {
  echo "=== Raw Source Frontmatter Check ==="
  local count=0

  while read -r file; do
    local rel="${file#"$VAULT"/}"

    if ! head -1 "$file" | grep -q '^---'; then
      echo "  FAIL: $rel — missing frontmatter"
      ((count++))
      continue
    fi

    local has_title=false has_source=false has_date_added=false
    local in_fm=false
    while IFS= read -r line; do
      if [[ "$line" == "---" ]]; then
        if $in_fm; then break; else in_fm=true; continue; fi
      fi
      if $in_fm; then
        [[ "$line" =~ ^title: ]] && has_title=true
        [[ "$line" =~ ^source: ]] && has_source=true
        [[ "$line" =~ ^date-added: ]] && has_date_added=true
      fi
    done < "$file"

    local missing=""
    $has_title || missing+="title "
    $has_source || missing+="source "
    $has_date_added || missing+="date-added "

    if [[ -n "$missing" ]]; then
      echo "  WARN: $rel — missing: $missing"
      ((count++))
    fi
  done < <(find_raw_files)

  if [[ "$count" -eq 0 ]]; then
    echo "  OK"
  fi
  ERRORS=$((ERRORS + count))
  echo
}

check_links() {
  echo "=== Broken Wikilinks ==="

  local slugs_file links_file results_file
  slugs_file=$(mktemp)
  links_file=$(mktemp)
  results_file=$(mktemp)

  # Step 1: Build slug index
  find "$VAULT" -name '*.md' -type f \
    -not -path "$VAULT/.obsidian/*" \
    -not -path "$VAULT/private/*" | while read -r f; do
    basename "$f" .md
    rel="${f#"$VAULT"/}"
    echo "${rel%.md}"
  done | tr '[:upper:]' '[:lower:]' | sort -u > "$slugs_file"

  # Step 2: Extract wikilinks, skipping fenced code blocks and inline code
  local filelist
  filelist=$(mktemp)
  find "$VAULT" -name '*.md' -type f \
    -not -path "$VAULT/raw/*" \
    -not -path "$VAULT/private/*" \
    -not -path "$VAULT/.obsidian/*" | sort > "$filelist"

  : > "$links_file"
  while read -r f; do
    rel="${f#"$VAULT"/}"
    sed '/^```/,/^```/d' "$f" \
      | sed 's/`[^`]*`//g' \
      | grep -o '\[\[[^]]*\]\]' 2>/dev/null \
      | sed 's/\[\[//;s/\]\]//;s/[\\|].*//' \
      | sed 's/#.*//' \
      | grep -v '^$' \
      | sed "s|^|${rel}	|" \
      >> "$links_file" || true
  done < "$filelist"
  rm -f "$filelist"

  # Step 3: Check each link against the slug index
  while IFS=$'\t' read -r src target; do
    target_lower=$(echo "$target" | tr '[:upper:]' '[:lower:]')
    if ! grep -qxF "$target_lower" "$slugs_file"; then
      echo "  WARN: $src → [[$target]] (not found)"
    fi
  done < "$links_file" > "$results_file"

  local count
  count=$(wc -l < "$results_file" | tr -d ' ')
  if [[ "$count" -gt 0 ]]; then
    cat "$results_file"
  else
    echo "  OK"
  fi
  ERRORS=$((ERRORS + count))
  rm -f "$slugs_file" "$links_file" "$results_file"
  echo
}

check_orphans() {
  echo "=== Orphan Pages (no inbound links) ==="

  local targets_file results_file
  targets_file=$(mktemp)
  results_file=$(mktemp)

  # Step 1: Extract all link targets (lowercase), skipping code blocks
  local raw_targets
  raw_targets=$(mktemp)
  : > "$raw_targets"
  local filelist2
  filelist2=$(mktemp)
  find "$VAULT" -name '*.md' -type f \
    -not -path "$VAULT/raw/*" \
    -not -path "$VAULT/private/*" \
    -not -path "$VAULT/.obsidian/*" | sort > "$filelist2"

  while read -r f; do
    sed '/^```/,/^```/d' "$f" \
      | sed 's/`[^`]*`//g' \
      | grep -o '\[\[[^]]*\]\]' 2>/dev/null \
      >> "$raw_targets" || true
  done < "$filelist2"
  rm -f "$filelist2"

  sed 's/\[\[//;s/\]\]//;s/|.*//' "$raw_targets" | sed 's/#.*//' \
    | grep -v '^$' | tr '[:upper:]' '[:lower:]' | sort -u > "$targets_file"

  rm -f "$raw_targets"

  # Step 2: Check each page against targets
  find_wiki_pages | while read -r f; do
    rel="${f#"$VAULT"/}"
    slug=$(basename "$f" .md)
    rel_no_ext="${rel%.md}"

    [[ "$slug" == "index" ]] && continue
    [[ "$rel" == "meta/log.md" ]] && continue

    slug_lower=$(echo "$slug" | tr '[:upper:]' '[:lower:]')
    rel_lower=$(echo "$rel_no_ext" | tr '[:upper:]' '[:lower:]')

    if ! grep -qxF "$slug_lower" "$targets_file" && ! grep -qxF "$rel_lower" "$targets_file"; then
      echo "  WARN: $rel — no inbound links"
    fi
  done > "$results_file"

  local count
  count=$(wc -l < "$results_file" | tr -d ' ')
  if [[ "$count" -gt 0 ]]; then
    cat "$results_file"
  else
    echo "  OK"
  fi
  ERRORS=$((ERRORS + count))
  rm -f "$targets_file" "$results_file"
  echo
}

# Parse args
case "${1:-}" in
  ""|all)
    check_frontmatter
    check_raw_frontmatter
    check_links
    check_orphans
    echo "=== Summary ==="
    if [[ "$ERRORS" -eq 0 ]]; then
      echo "All checks passed."
    else
      echo "$ERRORS issue(s) found."
    fi
    exit $((ERRORS > 0 ? 1 : 0))
    ;;
  frontmatter)
    check_frontmatter
    ;;
  raw)
    check_raw_frontmatter
    ;;
  links)
    check_links
    ;;
  orphans)
    check_orphans
    ;;
  *)
    echo "Usage: wiki-lint [all|frontmatter|raw|links|orphans]" >&2
    exit 1
    ;;
esac

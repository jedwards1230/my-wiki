#!/usr/bin/env bash
# wiki-queue — List unprocessed raw sources (missing 'ingested' frontmatter)
#
# Usage:
#   wiki-queue              List all unprocessed raw files
#   wiki-queue --count      Just show the count
#   wiki-queue --generate   Regenerate meta/ingest-queue.md
#
# Environment:
#   WIKI_VAULT  Path to the wiki vault (default: /data/vault or ~/Obsidian/home-wiki)

set -euo pipefail

# Resolve vault path
if [[ -n "${WIKI_VAULT:-}" ]]; then
  VAULT="$WIKI_VAULT"
elif [[ -d /data/vault ]]; then
  VAULT=/data/vault
elif [[ -d "$HOME/Obsidian/home-wiki" ]]; then
  VAULT="$HOME/Obsidian/home-wiki"
else
  echo "Error: Cannot find wiki vault. Set WIKI_VAULT." >&2
  exit 1
fi

RAW_DIR="$VAULT/raw"
QUEUE_FILE="$VAULT/meta/ingest-queue.md"

# Find all raw .md files missing 'ingested:' in frontmatter
find_unprocessed() {
  if [[ ! -d "$RAW_DIR" ]]; then
    return
  fi

  find "$RAW_DIR" -name '*.md' -type f | sort | while read -r file; do
    # Check if file has 'ingested:' in frontmatter (between --- markers)
    local in_frontmatter=false
    local has_ingested=false
    while IFS= read -r line; do
      if [[ "$line" == "---" ]]; then
        if $in_frontmatter; then
          break  # end of frontmatter
        else
          in_frontmatter=true
          continue
        fi
      fi
      if $in_frontmatter && [[ "$line" =~ ^ingested: ]]; then
        has_ingested=true
        break
      fi
    done < "$file"

    if ! $has_ingested; then
      echo "$file"
    fi
  done
}

list_unprocessed() {
  local files
  files=$(find_unprocessed)
  if [[ -z "$files" ]]; then
    echo "All raw sources have been ingested."
    return
  fi

  while read -r file; do
    local rel="${file#"$VAULT"/}"
    local title=""
    local source=""
    local date_added=""

    # Extract frontmatter fields
    local in_fm=false
    while IFS= read -r line; do
      if [[ "$line" == "---" ]]; then
        if $in_fm; then break; else in_fm=true; continue; fi
      fi
      if $in_fm; then
        [[ "$line" =~ ^title:\ *(.*) ]] && title="${BASH_REMATCH[1]}"
        [[ "$line" =~ ^source:\ *(.*) ]] && source="${BASH_REMATCH[1]}"
        [[ "$line" =~ ^date-added:\ *(.*) ]] && date_added="${BASH_REMATCH[1]}"
      fi
    done < "$file"

    printf "%-50s  %s  %s\n" "$rel" "${date_added:---}" "${title:-$(basename "$file" .md)}"
  done <<< "$files"
}

count_unprocessed() {
  local count
  count=$(find_unprocessed | wc -l | tr -d ' ')
  echo "$count unprocessed raw source(s)"
}

generate_queue() {
  local files
  files=$(find_unprocessed)

  cat > "$QUEUE_FILE" << EOF
---
title: Ingest Queue
tags:
  - meta
date: $(date +%Y-%m-%d)
---

Auto-generated by \`wiki-queue --generate\`. Do not edit manually.

EOF

  if [[ -z "$files" ]]; then
    echo "No unprocessed raw sources." >> "$QUEUE_FILE"
    echo "Generated $QUEUE_FILE (empty queue)"
    return
  fi

  echo "| File | Added | Title |" >> "$QUEUE_FILE"
  echo "|------|-------|-------|" >> "$QUEUE_FILE"

  while read -r file; do
    local rel="${file#"$VAULT"/}"
    local title="" date_added=""

    local in_fm=false
    while IFS= read -r line; do
      if [[ "$line" == "---" ]]; then
        if $in_fm; then break; else in_fm=true; continue; fi
      fi
      if $in_fm; then
        [[ "$line" =~ ^title:\ *(.*) ]] && title="${BASH_REMATCH[1]}"
        [[ "$line" =~ ^date-added:\ *(.*) ]] && date_added="${BASH_REMATCH[1]}"
      fi
    done < "$file"

    echo "| \`$rel\` | ${date_added:---} | ${title:-$(basename "$file" .md)} |" >> "$QUEUE_FILE"
  done <<< "$files"

  local count
  count=$(echo "$files" | wc -l | tr -d ' ')
  echo "Generated $QUEUE_FILE ($count item(s))"
}

# Parse args
case "${1:-}" in
  "")
    list_unprocessed
    ;;
  --count)
    count_unprocessed
    ;;
  --generate)
    generate_queue
    ;;
  *)
    echo "Usage: wiki-queue [--count|--generate]" >&2
    exit 1
    ;;
esac

#!/usr/bin/env bash
# wiki-activity — Append a structured entry to today's activity log
#
# Usage:
#   wiki-activity <type> <title> [options]
#
# Types: ingest, edit, create, lint, note, migrate
#
# Options:
#   --touched <page> [page...]   Pages created or edited (auto-linked as [[wikilinks]])
#   --summary <text>             Description of what was done (default: title reused)
#   --time <HH:MM>               Override timestamp (default: current time)
#
# Examples:
#   wiki-activity create "Lint scripts" --touched project/home-wiki meta/todo
#   wiki-activity ingest "Karpathy LLM Wiki" --touched project/home-wiki --summary "Ingested gist, created project page"
#   wiki-activity note "MCP server design thoughts" --summary "Leaning toward Go service"
#   wiki-activity edit "Schema restructure" --touched meta/schema --time 20:30
#
# Environment:
#   WIKI_VAULT  Path to the wiki vault (default: /data/vault or ~/Obsidian/home-wiki)

set -euo pipefail

VALID_TYPES="ingest edit create lint note migrate"

usage() {
  cat >&2 << 'EOF'
wiki-activity — Append a structured entry to today's activity log

Usage:
  wiki-activity <type> <title> [options]

Types:
  ingest    Processed a raw source into wiki pages
  edit      Updated existing wiki pages
  create    Created new wiki pages (no raw source)
  lint      Ran maintenance/health checks
  note      Loose context that might become a page later
  migrate   Migrated content from another vault or system

Options:
  --touched <page> [page...]   Pages created or edited (auto-linked as [[wikilinks]])
                               Use page paths without .md: meta/schema, project/home-wiki
  --summary <text>             Description of what was done (wrap in quotes)
  --time <HH:MM>               Override timestamp (default: current time)

Examples:
  wiki-activity create "Lint scripts" --touched project/home-wiki meta/todo
  wiki-activity ingest "Karpathy gist" --touched project/home-wiki --summary "Ingested gist, created project page"
  wiki-activity note "MCP server thoughts" --summary "Leaning toward Go service"
  wiki-activity edit "Schema restructure" --touched meta/schema --time 20:30

Environment:
  WIKI_VAULT  Path to the wiki vault (default: /data/vault or ~/Obsidian/home-wiki)

Notes:
  - Always wrap --summary and title in quotes to avoid shell word-splitting
  - Avoid special characters in title/summary: | ` [ ] are used in log formatting
  - --touched pages are auto-linked as [[wikilinks]] in the activity entry
  - The script auto-updates meta/log.md with entry count and hash
EOF
  exit 1
}

# Resolve vault path
if [[ -n "${WIKI_VAULT:-}" ]]; then
  VAULT="$WIKI_VAULT"
elif [[ -d /data/vault ]]; then
  VAULT=/data/vault
elif [[ -d "$HOME/Obsidian/home-wiki" ]]; then
  VAULT="$HOME/Obsidian/home-wiki"
else
  echo "Error: Cannot find wiki vault. Set WIKI_VAULT." >&2
  exit 1
fi

ACTIVITY_DIR="$VAULT/meta/activity"
LOG_INDEX="$VAULT/meta/log.md"
TODAY=$(date +%Y-%m-%d)
DAILY_FILE="$ACTIVITY_DIR/$TODAY.md"

# Help and arg check
if [[ $# -lt 1 || "$1" == "--help" || "$1" == "-h" ]]; then
  usage
fi

if [[ $# -lt 2 ]]; then
  echo "Error: Missing arguments." >&2
  echo "" >&2
  usage
fi

TYPE="$1"
TITLE="$2"
shift 2

# Validate type
if ! echo "$VALID_TYPES" | grep -qw "$TYPE"; then
  echo "Error: Invalid type '$TYPE'. Must be one of: $VALID_TYPES" >&2
  exit 1
fi

# Sanitize title — strip characters that break log format (|, `, newlines)
TITLE=$(echo "$TITLE" | tr -d '|`' | tr '\n' ' ' | sed 's/[[:space:]]*$//')

if [[ -z "$TITLE" ]]; then
  echo "Error: Title cannot be empty after sanitization." >&2
  exit 1
fi

# Parse options
TOUCHED=()
SUMMARY=""
TIME=$(date +%H:%M)

while [[ $# -gt 0 ]]; do
  case "$1" in
    --touched)
      shift
      while [[ $# -gt 0 && ! "$1" =~ ^-- ]]; do
        TOUCHED+=("$1")
        shift
      done
      ;;
    --summary)
      shift
      SUMMARY="$1"
      shift
      ;;
    --time)
      shift
      TIME="$1"
      shift
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
done

# Sanitize summary
if [[ -n "$SUMMARY" ]]; then
  SUMMARY=$(echo "$SUMMARY" | tr '\n' ' ' | sed 's/[[:space:]]*$//')
fi

# Validate time format
if ! echo "$TIME" | grep -qE '^[0-9]{1,2}:[0-9]{2}$'; then
  echo "Error: Invalid time format '$TIME'. Use HH:MM." >&2
  exit 1
fi

# Build the entry
ENTRY="### $TIME | $TYPE | $TITLE"

# Build description with wikilinks for touched files
if [[ -n "$SUMMARY" ]]; then
  DESC="$SUMMARY"
elif [[ ${#TOUCHED[@]} -gt 0 ]]; then
  DESC="Updated ${#TOUCHED[@]} page(s)."
else
  DESC=""
fi

# Append wikilinks for touched pages
if [[ ${#TOUCHED[@]} -gt 0 ]]; then
  LINKS=""
  for page in "${TOUCHED[@]}"; do
    # Strip .md extension if provided
    page="${page%.md}"
    if [[ -n "$LINKS" ]]; then
      LINKS="$LINKS, [[$page]]"
    else
      LINKS="[[$page]]"
    fi
  done
  if [[ -n "$DESC" ]]; then
    DESC="$DESC Touched: $LINKS."
  else
    DESC="Touched: $LINKS."
  fi
fi

# Create daily file if it doesn't exist
if [[ ! -f "$DAILY_FILE" ]]; then
  mkdir -p "$ACTIVITY_DIR"
  cat > "$DAILY_FILE" << EOF
---
title: "$TODAY"
tags:
  - meta/activity
date: $TODAY
---

EOF
  echo "Created $DAILY_FILE"
fi

# Append entry
echo "" >> "$DAILY_FILE"
echo "$ENTRY" >> "$DAILY_FILE"
if [[ -n "$DESC" ]]; then
  echo "$DESC" >> "$DAILY_FILE"
fi

echo "Logged: $TIME | $TYPE | $TITLE"

# Update log index
# Count entries (lines starting with ###)
ENTRY_COUNT=$(grep -c '^### ' "$DAILY_FILE" || true)

# Compute hash
HASH=$(md5sum "$DAILY_FILE" | cut -c1-6)

# Build the index line
INDEX_LINE="## [$TODAY] $ENTRY_COUNT changes | \`$HASH\` | $TITLE | [[meta/activity/$TODAY]]"

# Check if today already has an entry in the index
if grep -q "^\## \[$TODAY\]" "$LOG_INDEX" 2>/dev/null; then
  # Replace existing line — use a temp file for portability
  TEMP=$(mktemp)
  while IFS= read -r line; do
    if echo "$line" | grep -q "^\## \[$TODAY\]"; then
      echo "$INDEX_LINE"
    else
      echo "$line"
    fi
  done < "$LOG_INDEX" > "$TEMP"
  mv "$TEMP" "$LOG_INDEX"
else
  # Append new line
  echo "$INDEX_LINE" >> "$LOG_INDEX"
fi

echo "Updated meta/log.md ($ENTRY_COUNT entries, hash: $HASH)"

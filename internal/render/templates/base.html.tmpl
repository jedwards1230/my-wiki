<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ .Title }} — {{ .SiteTitle }}</title>
{{- if .Description }}
<meta name="description" content="{{ .Description }}">
{{- end }}
<link rel="stylesheet" href="/_/static/wiki.css?v={{ .Version }}">
{{- if .HasMath }}
<link rel="stylesheet" href="/_/static/vendor/katex/katex.min.css">
{{- end }}
<link rel="canonical" href="{{ .RelativeURL }}">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 32 32%22%3E%3Crect width=%2232%22 height=%2232%22 rx=%226%22 fill=%22%23284b63%22/%3E%3Ctext x=%2216%22 y=%2222%22 font-family=%22ui-sans-serif,system-ui,sans-serif%22 font-size=%2220%22 font-weight=%22700%22 text-anchor=%22middle%22 fill=%22white%22%3EW%3C/text%3E%3C/svg%3E">
<link rel="alternate" type="application/rss+xml" title="{{ .SiteTitle }} RSS feed" href="{{ if .BaseURL }}{{ .BaseURL }}{{ end }}/index.xml">

{{/* Open Graph + Twitter Card — drives social link previews. */}}
<meta property="og:site_name" content="{{ .SiteTitle }}">
<meta property="og:title" content="{{ .Title }}">
<meta property="og:type" content="article">
{{- if .Description }}
<meta property="og:description" content="{{ .Description }}">
{{- end }}
{{- if .BaseURL }}
<meta property="og:url" content="{{ .BaseURL }}{{ .RelativeURL }}">
{{- end }}
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="{{ .Title }}">
{{- if .Description }}
<meta name="twitter:description" content="{{ .Description }}">
{{- end }}

<meta name="generator" content="my-wiki native renderer">
</head>
<body hx-ext="morph" data-active-path="{{ .ActivePath }}"
      x-data="{
        drawer: false,
        rightCollapsed: $persist(false).as('rightRailCollapsed'),
        appearanceOpen: $persist(false).as('appearancePanelOpen'),
        textSize: $persist('standard').as('readingTextSize'),
        widthMode: $persist('standard').as('readingWidth'),
        colorMode: $persist('auto').as('darkmode')
      }"
      :class="{ 'right-rail-collapsed': rightCollapsed }"
      :data-appearance-open="appearanceOpen.toString()"
      x-init="
        $watch('textSize',  v => document.documentElement.setAttribute('data-text-size', v));
        $watch('widthMode', v => document.body.setAttribute('data-reading-width', v));
        $watch('colorMode', v => {
          if (v === 'light' || v === 'dark') {
            document.documentElement.setAttribute('data-theme', v);
          } else {
            document.documentElement.removeAttribute('data-theme');
          }
        });
      ">

<a class="skip-link" href="#main">Skip to content</a>
<div id="a11y-announcer" class="sr-only" role="status" aria-live="polite"></div>

{{/* Mobile header — visible only at narrow viewports. Hamburger
     opens the left sidebar as a slide-in drawer; title links home. */}}
<header class="mobile-header">
  <button type="button" class="sidebar-toggle" :aria-expanded="drawer.toString()" aria-label="Toggle navigation" x-on:click="drawer = !drawer">
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
  </button>
  <a class="mobile-title" href="/">{{ .SiteTitle }}</a>
</header>

<div class="drawer-backdrop" x-show="drawer" x-transition.opacity x-on:click="drawer = false" aria-hidden="true"></div>

<div class="layout">

  <aside class="sidebar sidebar-left" :class="{ 'is-open': drawer }" aria-label="Navigation" hx-boost="true" hx-target="#main" hx-select="#main, #page-tools" hx-swap="outerHTML show:window:top" x-on:click="if ($event.target.closest('a')) drawer = false">
    <h1 class="page-title"><a href="/">{{ .SiteTitle }}</a></h1>
    <div class="search" x-data="{
        q: '', results: [], open: false, idx: -1, seq: 0,
        urlFor(r) {
          if (!r) return '#';
          let p = (r.path || '').replace(/\.md$/, '');
          if (p === 'index') return '/';
          if (p.endsWith('/index')) p = p.slice(0, -'/index'.length);
          return '/' + p + '/';
        }
      }" x-on:click.outside="open = false">
      <input type="search" class="search-input" placeholder="Search" autocomplete="off"
             x-model="q"
             x-on:input.debounce.150ms="
               if (q.trim().length < 2) { results = []; open = false; idx = -1; return; }
               const mySeq = ++seq;
               fetch('/api/search?q=' + encodeURIComponent(q) + '&limit=8')
                 .then(r => r.json())
                 .then(j => {
                   if (mySeq !== seq) return;
                   results = (j.data && j.data.results) || [];
                   open = results.length > 0;
                   idx = -1;
                 })
                 .catch(() => { if (mySeq === seq) { results = []; open = false; } });"
             x-on:keydown.escape="open = false"
             x-on:keydown.arrow-down.prevent="if (results.length) idx = Math.min(idx + 1, results.length - 1)"
             x-on:keydown.arrow-up.prevent="if (results.length && idx > 0) idx = idx - 1"
             x-on:keydown.enter.prevent="if (idx >= 0 && results[idx]) window.location.href = urlFor(results[idx])"
             x-on:focus="open = results.length > 0">
      <ul class="search-results" x-show="open" x-transition.opacity>
        <template x-for="(r, i) in results" :key="r.path || i">
          <li :class="{ 'is-active': i === idx }">
            <a :href="urlFor(r)" x-text="r.title || r.path"></a>
          </li>
        </template>
      </ul>
    </div>
    {{- if .Explorer }}
    <nav class="explorer" aria-label="Site navigation">
      <details class="explorer-top" open>
        <summary class="explorer-top-title">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="5 8 14 8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="fold-icon" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
          <span>Explorer</span>
        </summary>
        {{ renderExplorer .Explorer }}
      </details>
    </nav>
    {{- end }}
  </aside>

  <main id="main" tabindex="-1" hx-boost="true" hx-target="#main" hx-select="#main, #page-tools" hx-swap="outerHTML show:window:top">
    {{ template "content" . }}
  </main>

  <aside class="sidebar sidebar-right" aria-label="Page tools">
    <button type="button" class="right-rail-toggle"
            :title="rightCollapsed ? 'Show page tools' : 'Hide page tools'"
            :aria-label="rightCollapsed ? 'Show page tools' : 'Hide page tools'"
            :aria-expanded="(!rightCollapsed).toString()"
            x-on:click="rightCollapsed = !rightCollapsed">
      <span aria-hidden="true" x-text="rightCollapsed ? '«' : '»'"></span>
    </button>
    {{/* Graph + TOC + Backlinks form one scrollable block. When the
         Appearance panel opens below, it claims its own height and the
         wrapper shrinks — content overflowing the wrapper scrolls.
         The id="page-tools" target lets htmx OOB-swap this block on
         every SPA nav so the graph, TOC, and backlinks stay synced
         with the active page (see wiki.js htmx:afterSwap and
         RenderFragment in internal/render/render.go). Always rendered
         — empty on list pages — so the OOB target exists even when
         navigating list → content. The block lives in its own named
         template so the htmx fragment response can emit the same
         markup without re-rendering the whole shell. */}}
    {{ template "page-tools" . }}
    {{/* Appearance sits at the bottom of the rail and collapses
         independently from the whole-rail toggle. Default is closed —
         most reading sessions never need to open it. The icon button
         is always present so the entry point is obvious; clicking it
         expands the panel inline above. The wrapper class drives both
         the collapsed-vs-open layout and the bootstrap pre-paint hide
         (see body[data-appearance-open]). */}}
    <section class="appearance" :class="{ 'is-open': appearanceOpen }" aria-label="Appearance">
      <div class="appearance-panel" x-show="appearanceOpen">
        <h2>Appearance</h2>
        <fieldset class="appearance-group">
          <legend>Text</legend>
          <div class="appearance-options" role="radiogroup">
            <button type="button" role="radio" :aria-checked="(textSize === 'small').toString()" :class="{ 'is-active': textSize === 'small' }" x-on:click="textSize = 'small'">Small</button>
            <button type="button" role="radio" :aria-checked="(textSize === 'standard').toString()" :class="{ 'is-active': textSize === 'standard' }" x-on:click="textSize = 'standard'">Standard</button>
            <button type="button" role="radio" :aria-checked="(textSize === 'large').toString()" :class="{ 'is-active': textSize === 'large' }" x-on:click="textSize = 'large'">Large</button>
          </div>
        </fieldset>
        <fieldset class="appearance-group">
          <legend>Width</legend>
          <div class="appearance-options" role="radiogroup">
            <button type="button" role="radio" :aria-checked="(widthMode === 'standard').toString()" :class="{ 'is-active': widthMode === 'standard' }" x-on:click="widthMode = 'standard'">Standard</button>
            <button type="button" role="radio" :aria-checked="(widthMode === 'wide').toString()" :class="{ 'is-active': widthMode === 'wide' }" x-on:click="widthMode = 'wide'">Wide</button>
          </div>
        </fieldset>
        <fieldset class="appearance-group">
          <legend>Color</legend>
          <div class="appearance-options" role="radiogroup">
            <button type="button" role="radio" :aria-checked="(colorMode === 'auto').toString()" :class="{ 'is-active': colorMode === 'auto' }" x-on:click="colorMode = 'auto'">Automatic</button>
            <button type="button" role="radio" :aria-checked="(colorMode === 'light').toString()" :class="{ 'is-active': colorMode === 'light' }" x-on:click="colorMode = 'light'">Light</button>
            <button type="button" role="radio" :aria-checked="(colorMode === 'dark').toString()" :class="{ 'is-active': colorMode === 'dark' }" x-on:click="colorMode = 'dark'">Dark</button>
          </div>
        </fieldset>
      </div>
      <button type="button" class="appearance-toggle"
              :title="appearanceOpen ? 'Hide appearance' : 'Appearance'"
              :aria-label="appearanceOpen ? 'Hide appearance panel' : 'Open appearance panel'"
              :aria-expanded="appearanceOpen.toString()"
              x-on:click="appearanceOpen = !appearanceOpen">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 20l5-14 5 14"/><path d="M5.5 16h7"/><circle cx="18.5" cy="17.5" r="3.5"/></svg>
        <span class="appearance-toggle-label">Appearance</span>
      </button>
    </section>
  </aside>

</div>

<footer class="site-footer">
  <p>my-wiki v{{ .Version }}</p>
</footer>

<script src="/_/static/vendor/htmx.min.js" defer></script>
<script src="/_/static/vendor/htmx-idiomorph-ext.min.js" defer></script>
<script src="/_/static/vendor/alpine-persist.min.js" defer></script>
<script src="/_/static/vendor/alpine.min.js" defer></script>
<script src="/_/static/wiki.js?v={{ .Version }}" defer></script>
{{- /*
  KaTeX and Mermaid loaders live in wiki.js (see ensureKatex /
  ensureMermaid) so they fire both on initial DOMContentLoaded and
  after every htmx swap. Conditional <script> tags here would not
  survive a #main fragment swap, causing pages reached via hx-boost
  to display raw markdown until a hard refresh.
*/ -}}

</body>
</html>

{{ define "content" }}
<article class="page" data-slug="{{ .Slug }}">
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
      {{- range .BreadcrumbItems }}
      <li{{ if .Last }} aria-current="page"{{ end }}>
        {{- if .Last -}}
          {{ .Label }}
        {{- else -}}
          <a href="{{ .URL }}">{{ .Label }}</a>
        {{- end -}}
      </li>
      {{- end }}
    </ol>
  </nav>
  <header class="article-header">
    <h1 class="article-title">{{ .Title }}</h1>
    {{- if or (not .Created.IsZero) .ReadingTime }}
    <div class="article-meta">
      {{- if not .Created.IsZero }}<time datetime="{{ formatDate .Created }}">{{ formatDateLong .Created }}</time>{{ end }}
      {{- if .ReadingTime }} · <span class="reading-time">{{ readingTime .ReadingTime }}</span>{{ end }}
    </div>
    {{- end }}
    {{- if .Tags }}
    <ul class="tags">
      {{- range .Tags }}
      <li><a href="/tags/{{ . }}/" class="internal tag-link">{{ . }}</a></li>
      {{- end }}
    </ul>
    {{- end }}
    {{- if .IsRawSource }}
    <p class="raw-source-note">
      <span class="raw-source-badge">Source</span>
      <span class="raw-source-text">Verbatim source file from <code>raw/</code>.</span>
      <a class="raw-link" href="{{ .SourceURL }}" hx-boost="false">View source</a>
    </p>
    {{- else if and (not .IsListPage) .Slug }}
    <a class="raw-link" href="/{{ .Slug }}.md" hx-boost="false">View source</a>
    {{- end }}
  </header>

  {{- if and .DescriptionFromFrontmatter .Description }}
  <p class="article-description">{{ .Description }}</p>
  {{- end }}

  {{- if .Properties }}
  <dl class="article-properties">
    {{- range .Properties }}
    <div class="property">
      <dt>{{ .Label }}</dt>
      <dd>
        {{- range $i, $v := .Values }}
        {{- if $i }}<span class="property-sep">,</span> {{ end -}}
        {{- if $v.Href }}<a href="{{ $v.Href }}" class="external" rel="noopener noreferrer" target="_blank">{{ $v.Text }}</a>
        {{- else }}{{ $v.Text }}{{ end -}}
        {{- end }}
      </dd>
    </div>
    {{- end }}
  </dl>
  {{- end }}

  <div class="article-body">
    {{- if .IsListPage }}
      {{- if .ListEntries }}
      <ul class="list-entries">
        {{- range .ListEntries }}
        <li>
          <a href="{{ .URL }}">{{ .Title }}</a>
          {{- if .Description }} — {{ .Description }}{{ end }}
        </li>
        {{- end }}
      </ul>
      {{- else }}
      <p>Nothing here yet.</p>
      {{- end }}
    {{- else }}
      {{ .ContentHTML }}
    {{- end }}
  </div>
</article>
{{ end }}

{{/* page-tools — graph, TOC, backlinks for the current page. Rendered
     inline by base.html.tmpl and re-emitted by the htmx fragment
     response (see internal/render/render.go RenderFragment) so the
     right-rail stays in sync with #main on every SPA navigation. The
     hx-swap-oob attribute is what tells htmx to OOB-swap this block on
     the fragment response; it's a no-op on the initial full-page load
     since the browser doesn't process hx-* attributes itself. */}}
{{ define "page-tools" }}
<div id="page-tools" class="right-rail-main" hx-swap-oob="outerHTML">
  {{- if not .IsListPage }}
  {{- if .Slug }}
  <section class="graph" aria-label="Graph view">
    <h2>Graph View</h2>
    <canvas class="graph-canvas" data-slug="{{ .Slug }}" data-graph-src="/api/graph.json" width="280" height="200"></canvas>
  </section>
  {{- end }}
  {{- if .TOC }}
  <nav class="toc" aria-label="On this page">
    <h2>On this page</h2>
    <ul>
      {{- range .TOC }}
      <li class="toc-depth-{{ .Depth }}"><a href="#{{ .Anchor }}">{{ .Text }}</a></li>
      {{- end }}
    </ul>
  </nav>
  {{- end }}
  {{- if .Backlinks }}
  <section class="backlinks">
    <h2>Backlinks</h2>
    <ul>
      {{- range .Backlinks }}
      <li><a href="{{ .URL }}">{{ .Title }}</a></li>
      {{- end }}
    </ul>
  </section>
  {{- end }}
  {{- end }}
</div>
{{ end }}
